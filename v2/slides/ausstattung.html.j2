{# Ausstattung: 6-Bilder-Grid (3x2) + Detail-Text-Spalte links #}
<section class="slide slide-ausstattung" id="anchor-ausstattung">
  <div class="text-col">
    <div class="eyebrow">Ausstattung</div>
    <h2>Einrichten?<br>Schon erledigt.</h2>
    {% if lead %}<p class="lead">{{ lead }}</p>{% endif %}
    {% if detail %}<p class="detail">{{ detail }}</p>{% endif %}
  </div>
  <div class="image-grid">
    {% for img in images[:6] %}
    <div class="cell">
      {% if img %}<img src="{{ img }}" alt="">{% else %}<div class="ph"></div>{% endif %}
    </div>
    {% endfor %}
  </div>
</section>
