{# Projekt-Hero: großes Außenansicht-Bild + Beschreibung + Key-Facts #}
<section class="slide slide-projekt" id="anchor-projekt">
  <div class="img-side">
    {% if img %}<img src="{{ img }}" alt="">{% else %}<div class="img-placeholder"></div>{% endif %}
    <div class="overlay-tag">{{ stadt or '' }} · {{ stadtteil or '' }}</div>
  </div>
  <div class="text-side">
    <div class="eyebrow">Das Projekt</div>
    <h2 class="title">{{ projekt_titel or 'The Central' }}</h2>
    {% if intro %}<p class="lead">{{ intro }}</p>{% endif %}
    {% if features %}
    <div class="features">
      {% for f in features %}
      <div class="feat">
        <div class="feat-num">{{ f.value }}</div>
        <div class="feat-lbl">{{ f.label }}</div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</section>
