{# Schluss-Folie: Brand zentriert + Adresse/Kontakt #}
<section class="slide slide-schluss no-pageno" id="anchor-schluss">
  <div class="center">
    <div class="brand-big">INTERPRÉS</div>
    <div class="brand-sub-big">Immobilien · {{ stadt or '' }}</div>
    {% if intro %}<p class="lead">{{ intro }}</p>{% endif %}
    <div class="contact">
      {% if entwickler_name %}<div class="dev">{{ entwickler_name }}</div>{% endif %}
      {% if adresse %}<div>{{ adresse }}</div>{% endif %}
      {% if web %}<div>{{ web }}</div>{% endif %}
    </div>
  </div>
</section>
