{# Standort-Folie: Stadtteil-Lage + 3 Min-Karten (Uni / Bahnhof / Altstadt) + Hero-Bild #}
<section class="slide slide-standort" id="anchor-standort">
  <div class="standort-grid">
    <div class="text-side">
      <div class="eyebrow">Der Standort</div>
      <h2>{{ stadtteil or 'Stadtteil' }} – nah an allem</h2>
      <p class="lead">{{ lead }}</p>

      <div class="min-cards">
        {% for m in minutes %}
        <div class="min-card">
          <div class="min-val">{{ m.min }}<span>min</span></div>
          <div class="min-lbl">{{ m.label }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
    <div class="img-side">
      {% if img %}<img src="{{ img }}" alt="">{% else %}<div class="img-placeholder"></div>{% endif %}
    </div>
  </div>
</section>
