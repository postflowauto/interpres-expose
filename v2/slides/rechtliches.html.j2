{# Rechtliches: 2-Spalten-Lauftext + dezentes Hintergrundbild rechts #}
<section class="slide slide-rechtliches" id="anchor-rechtliches">
  <div class="text-col">
    <div class="eyebrow">Rechtliche Hinweise</div>
    <h2>Haftungsausschlüsse Prospektteil A</h2>
    <div class="cols">
      <div class="col">
        {% for p in paragraphs[0::2] %}<p>{{ p }}</p>{% endfor %}
      </div>
      <div class="col">
        {% for p in paragraphs[1::2] %}<p>{{ p }}</p>{% endfor %}
      </div>
    </div>
  </div>
  <div class="img-col">
    {% if img %}<img src="{{ img }}" alt="">{% endif %}
  </div>
</section>
