{# Inhaltsverzeichnis – 4 Spalten (Invest / Live / Stay / Know).
   Seitenzahlen werden nach dem Render via Playwright eingesetzt
   (siehe renderer.py: post_process_toc). Hier nur Anker-Markup. #}
<section class="slide slide-toc no-pageno" data-slide-type="toc">
  <div>
    <h2>
      <small>Inhalt · Prospektteil A</small>
      Übersicht
    </h2>
  </div>
  <div class="toc-grid">
    {% for col in chapters %}
    <div class="toc-col">
      <h3>{{ "%02d"|format(loop.index) }}</h3>
      <div class="ic">{{ col.icon or 'u' }} <span style="font-style:italic;">{{ col.tag }}</span></div>
      <div class="section">{{ col.title }}</div>
      {% for it in col.items %}
      <div class="item">
        <span>{{ it.label }}</span>
        <span class="pg" data-toc-anchor="{{ it.anchor }}">{{ it.page if it.page else '—' }}</span>
      </div>
      {% endfor %}
    </div>
    {% endfor %}
  </div>
</section>
