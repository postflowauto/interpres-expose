{# Greenliving: 4 Spalten Bullet-Texte links, 2 große Bilder rechts #}
<section class="slide slide-greenliving" id="anchor-greenliving">
  <div class="left">
    <div class="head">
      <div class="ic"><em>u</em> grow</div>
      <h2 class="title">{{ title or 'Einfach grüner.' }}</h2>
    </div>
    <div class="bullets">
      {% for b in bullets %}
      <div class="bullet">
        <div class="b-title">{{ b.title }}</div>
        <div class="b-desc">{{ b.desc }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
  <div class="right">
    <div class="img-frame img-1">
      {% if img1 %}<img src="{{ img1 }}" alt="">{% endif %}
    </div>
    <div class="content">
      <div class="eyebrow">Greenliving</div>
      <p class="lead">{{ lead }}</p>
    </div>
    <div class="img-frame img-2">
      {% if img2 %}<img src="{{ img2 }}" alt="">{% endif %}
    </div>
  </div>
</section>
