{# Kapitel-Trennfolie: Nummer + Titel links, Hero-Bild rechts #}
<section class="slide slide-kapitel" id="anchor-{{ anchor or '' }}" data-anchor="{{ anchor or '' }}">
  <div class="left">
    <div class="num">{{ "%02d"|format(num or 1) }}</div>
    <div class="subtitle">{{ tag or 'invest' }}</div>
    <div class="title">{{ title or 'Das Investment' }}</div>
    {% if lead %}<p class="lead">{{ lead }}</p>{% endif %}
  </div>
  <div class="right{% if not bild %} no-image{% endif %}">
    {% if bild %}<img src="{{ bild }}" alt="">{% endif %}
  </div>
</section>
