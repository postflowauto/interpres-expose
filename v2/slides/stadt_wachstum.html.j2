{# Stadt-Wachstum: links Stadtbild, rechts Stadtname (riesig) + Lead + Stat-Reihe #}
<section class="slide slide-stadt-wachstum" id="anchor-stadt_wachstum">
  <div class="img-side">
    {% if img %}<img src="{{ img }}" alt="">{% else %}<div style="width:100%;height:100%;background:linear-gradient(135deg,var(--navy-700),var(--navy-900));"></div>{% endif %}
  </div>
  <div class="text-side">
    <div class="eyebrow" style="margin-bottom:6mm;">Wachstum & Innovation</div>
    <div class="stadt-name">{{ stadt }}<br><em>{{ stadt_em or 'wächst.' }}</em></div>
    {% if lead %}<p class="lead">{{ lead }}</p>{% endif %}
    {% if stats %}
    <div class="stat-row">
      {% for st in stats %}
      <div class="stat">
        <div class="v">{{ st.v }}</div>
        <div class="l">{{ st.l }}</div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</section>
